# ==========================================
# VARIABLES DE ENTORNO GLOBALES (PLANTILLA)
# Renombra este archivo a ".env" y llena los valores
# ==========================================

# --------------------------
# Next.js (Base de datos Pacientes - Prisma)
# --------------------------
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# --------------------------
# Java Spring Boot (Base de datos Gestion)
# --------------------------
DB_URL=jdbc:postgresql://host:5432/postgres
DB_USER=tusuario
DB_PASS=tucontrasena
SPRING_PROFILES_ACTIVE=dev

# --------------------------
# Integracion Supabase Auth (Compartido)
# --------------------------
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_ISSUER=https://TU_PROYECTO.supabase.co/auth/v1
SUPABASE_JWKS_URI=https://TU_PROYECTO.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# --------------------------
# Otras configuraciones de puertos
# --------------------------
PORT=3000
# En Docker el BFF/Java alcanzan la blockchain por nombre de servicio.
BLOCKCHAIN_URL=http://ms-blockchain:3001
CORS_ORIGINS=http://localhost:4200

# --------------------------
# ms-blockchain (Polygon Amoy testnet, chainId 80002)
# --------------------------
# RPC publico de Amoy (funciona sin cuenta).
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
# PRIVATE_KEY de una wallet con MATIC de testnet (faucet.polygon.technology).
# Vacia => ms-blockchain arranca en modo SOLO LECTURA (verificar OK, registrar no).
# NUNCA commitees una llave real.
PRIVATE_KEY=
# Opcional: vacio => usa la address de block_movil/ms-blockchain/deployments/amoy.json
CONTRACT_ADDRESS=
POLYGONSCAN_API_KEY=
