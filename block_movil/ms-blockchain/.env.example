# ============================================================================
# .env.example — Template para ms-blockchain
# Copia este archivo como `.env` (esta en .gitignore) y rellena tus valores.
# ============================================================================

# === Servidor Express ===
PORT=3001
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# === Auth Supabase (mismo proyecto que ms-gestion) ===
# Si esta vacio, ms-blockchain corre en modo DEV sin auth (NO usar en prod).
SUPABASE_JWKS_URI=

# === Red blockchain: Polygon Amoy (testnet) ===
# Ya NO usamos un nodo Hardhat local. El servicio habla SIEMPRE con Amoy.
#   1. Consigue MATIC de testnet en https://faucet.polygon.technology
#   2. Usa la PRIVATE_KEY de una wallet con >= 0.5 MATIC (NUNCA la commitees)
#   3. AMOY_RPC_URL por defecto ya apunta al RPC publico de Amoy
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=<your_private_key>

# CONTRACT_ADDRESS es OPCIONAL: si lo dejas vacio, el server lee la address del
# ultimo deploy desde deployments/amoy.json automaticamente.
CONTRACT_ADDRESS=

# === Verificacion en explorer (opcional) ===
POLYGONSCAN_API_KEY=
