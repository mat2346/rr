        "expo-camera",
        {
          "cameraPermission": "Esta app usa la camara para tomar fotos de recetas y documentos clinicos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Esta app usa tu galeria para seleccionar imagenes o documentos clinicos."
        }
      ],
      "expo-document-picker",
      [
        "expo-location",
