        "NSLocationWhenInUseUsageDescription": "Esta app usa tu ubicacion para registrar la sucursal de la farmacia.",
        "NSFaceIDUsageDescription": "Esta app usa Face ID para confirmar tu identidad antes de operaciones criticas.",
        "NSMicrophoneUsageDescription": "Esta app usa el microfono para generar reportes por voz con IA."
      }
    },
    "android": {
      "adaptiveIcon": {
